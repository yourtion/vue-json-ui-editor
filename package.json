{
  "name": "vue-json-ui-editor",
  "version": "3.0.1",
  "description": "A Vue 3 JSON Schema based form editor component with TypeScript support",
  "type": "module",
  "main": "dist/vue-json-ui-editor.umd.js",
  "module": "dist/vue-json-ui-editor.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/vue-json-ui-editor.es.js",
      "require": "./dist/vue-json-ui-editor.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "build:lib": "vue-tsc && vite build --mode lib",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "type-check": "vue-tsc --noEmit",
    "lint": "biome check --write src/",
    "format": "biome format --write src/",
    "check": "npm run type-check && npm run lint && npm run test",
    "tag": "git tag v`node -p 'require(\"./package\").version'`",
    "prepublishOnly": "npm run check && npm run build:lib",
    "postpublish": "npm run tag && git push && git push --tags"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.21",
    "element-plus": "^2.11.1",
    "jsdom": "^23.0.0",
    "postcss-import": "^16.1.1",
    "typescript": "5.6.2",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.6.0",
    "vitest": "^1.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "2.0.29"
  },
  "peerDependencies": {
    "vue": "^3"
  },
  "keywords": [
    "vue",
    "vue3",
    "typescript",
    "json-schema",
    "form-editor",
    "ui-component",
    "vite"
  ],
  "author": "Yourtion <yourtion@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourtion/vue-json-ui-editor.git"
  },
  "bugs": {
    "url": "https://github.com/yourtion/vue-json-ui-editor/issues"
  },
  "homepage": "https://github.com/yourtion/vue-json-ui-editor#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.com/"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2"
  }
}
